# Public site URL (used for canonical links, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://strkan.cz

# Supabase (anonymous read-only access for public content)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, used by Server Actions for inserts
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile (form anti-spam)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@strkan.cz
RESEND_INBOX_OBCHOD=obchod@strkan.cz
RESEND_INBOX_HR=hr@strkan.cz

# Pipedrive (CRM sync — optional)
ENABLE_PIPEDRIVE_SYNC=false
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_BASE_URL=

# Revalidation webhook secret (POST /api/revalidate?secret=...)
REVALIDATE_SECRET=
